{
  "name": "test-ecosystem-ci",
  "version": "0.0.3",
  "description": "Run CI across the ecosystem",
  "homepage": "https://github.com/Gugustinette/ecosystem-ci#readme",
  "bugs": {
    "url": "https://github.com/Gugustinette/ecosystem-ci/issues"
  },
  "license": "MIT",
  "author": "Augustin Mercier <gugustinette@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gugustinette/ecosystem-ci.git"
  },
  "funding": "https://github.com/sponsors/Gugustinette",
  "bin": {
    "ecosystem-ci": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown && clear && node ./dist/cli.mjs",
    "test": "pnpm run build && vitest",
    "test:run": "pnpm run build && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "release": "bumpp"
  },
  "dependencies": {
    "ansis": "^4.3.0",
    "cac": "^7.0.0",
    "giget": "^3.2.0",
    "unconfig-core": "^7.5.0",
    "unrun": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "bumpp": "^11.1.0",
    "obug": "^2.1.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.21.0"
}
